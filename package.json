{
  "name": "performancehud",
  "private": true,
  "version": "1.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:app": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && cp lib-package.json dist-lib/package.json && cp lib-README.md dist-lib/README.md",
    "publish:lib": "npm run build:lib && cd dist-lib && npm publish --access public",
    "release": "node scripts/bump-version.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
